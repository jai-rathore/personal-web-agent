# ─────────────────────────────────────────────────────────────────
# Personal Web Agent – environment variables
# Copy to .env and fill in real values before running
# ─────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development
BUILD_SHA=local-dev
ALLOWED_ORIGIN=http://localhost:3000
TZ=America/Los_Angeles

# ── Content ──────────────────────────────────────────────────────
CONTENT_DIR=../content

# ── Google Gemini / ADK ───────────────────────────────────────────
# Get your API key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Model selection (latest Gemini 3.1 models)
CHAT_MODEL=gemini-3.1-pro-preview
FAST_MODEL=gemini-3.1-flash-lite-preview

# ── Google OAuth2 (owner workspace access) ────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# App type: Web application
# Authorized redirect URI: http://localhost:8080/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Comma-separated list of Google emails that get owner (workspace) access
OWNER_EMAILS=jaiadityarathore@gmail.com

# Secret for signing JWT session tokens (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET=change_me_to_a_random_secret

# ── Rate Limiting ─────────────────────────────────────────────────
CHAT_RATE_LIMIT=60
CHAT_RATE_WINDOW=300
ACTION_RATE_LIMIT=5
ACTION_RATE_WINDOW=600

# ── Timeouts ──────────────────────────────────────────────────────
REQUEST_TIMEOUT=30
SSE_TIMEOUT=300

# ── SMTP (feedback form) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=jaiadityarathore@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM_EMAIL=noreply@jairathore.com
FEEDBACK_EMAIL=jaiadityarathore@gmail.com
